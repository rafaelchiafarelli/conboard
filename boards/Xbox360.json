    },
    "header": {
        "identifier": {
            "generics": {},
            "tags": {
                "ID_BUS": "usb",
                "ID_VENDOR_ID": "045e",
                "ID_MODEL_ID": "028e"
            },
            "executable": {
                "exec": "/conboard/LowLevel/Joystick/build/conJoyS"
            }
        },
        "actions": []
